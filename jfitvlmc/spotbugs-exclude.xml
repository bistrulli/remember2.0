<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
	<!-- Legacy standalone utilities excluded from main flow -->
	<Match>
		<Class name="fitvlmc.SelfLoopRemover"/>
	</Match>
	<Match>
		<Class name="fitvlmc.DebugEcfComparison"/>
	</Match>
	<!-- EcfNavigator uses static learner field intentionally for static helper methods -->
	<Match>
		<Class name="fitvlmc.EcfNavigator"/>
		<Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
	</Match>
</FindBugsFilter>
